---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — Sand Hill Equestrian Events" description="The page you're looking for doesn't exist. Head back to the Sand Hill Equestrian Events homepage.">
  <Nav />

  <main id="main-content">
  <section class="not-found">
    <div class="container">
      <p class="label">404</p>
      <h1>Page Not Found</h1>
      <p class="not-found-message">
        Looks like this trail leads nowhere. The page you're looking for
        may have been moved or no longer exists.
      </p>
      <a href="/" class="btn btn-primary">Back to Homepage</a>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  .not-found {
    background-color: var(--color-cream);
    padding-block: var(--space-xl);
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .not-found .label {
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .not-found h1 {
    margin-bottom: 1.25rem;
  }

  .not-found-message {
    max-width: 44ch;
    margin-bottom: 2rem;
  }

</style>
